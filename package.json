		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/4e913a56-fd99-4372-0586-9f1364173100/preview",
		"publish": true
	},
	"dependencies": {
		"@clerk/localizations": "^3.34.0",
		"@clerk/nextjs": "^6.36.7",
		"@elevenlabs/react": "^0.14.2",
		"@opennextjs/cloudflare": "1.14.0",
		"google-auth-library": "^9.15.1",
		"lucide-react": "^0.577.0",
		"next": "16.0.7",
		"react": "19.2.1",
		"react-dom": "19.2.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3",
		"@tailwindcss/postcss": "4.1.17",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"eslint": "9.39.2",
		"eslint-config-next": "16.0.7",
		"tailwindcss": "4.1.17",
		"typescript": "5.9.3",
		"wrangler": "4.56.0"
	},
	"private": true,
	"packageManager": "yarn@4.5.0",
	"scripts": {
		"build": "node scripts/generate-blog-data.js && next build",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",
		"check": "npm run build && tsc",
		"clear:d1": "node scripts/clear-d1-data.mjs --remote",
		"deploy": "node scripts/generate-blog-data.js && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"dev": "node scripts/generate-blog-data.js && next dev --webpack",
		"dev:turbo": "node scripts/generate-blog-data.js && next dev --turbopack",
		"import:d1": "node scripts/import-input-to-d1.mjs --remote",
		"import:speaking": "node scripts/import-speaking-questions.mjs --remote",
		"import:word-review": "node scripts/import-word-review-json.mjs --remote",
		"lint": "next lint",
		"preview": "node scripts/generate-blog-data.js && opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"generate:listening-analyses": "node scripts/generate-listening-group-analyses.mjs --remote",
		"generate:speaking-audio": "node scripts/generate-speaking-question-audio.mjs --remote",
		"translate:transcript-detail": "node scripts/translate-transcript-detail-to-test.mjs --remote",
		"transcribe:paper-parts": "node scripts/transcribe-paper-parts.mjs --remote",
		"start": "next start"
	}
}
